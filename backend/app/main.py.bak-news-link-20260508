@app.on_event("startup")
def startup() -> None:
    Base.metadata.create_all(bind=engine)
    _ensure_category_columns()


def _ensure_category_columns() -> None:
    """Lightweight migration for existing SQLite DBs without Alembic."""
    with engine.begin() as conn:
        article_cols = {
            row[1] for row in conn.execute(text("PRAGMA table_info(articles)"))
        }
        if "category_id" not in article_cols:
            conn.execute(text("ALTER TABLE articles ADD COLUMN category_id INTEGER"))

        album_cols = {
            row[1] for row in conn.execute(text("PRAGMA table_info(albums)"))
        }
        if "category_id" not in album_cols:
            conn.execute(text("ALTER TABLE albums ADD COLUMN category_id INTEGER"))

        category_cols = {
            row[1] for row in conn.execute(text("PRAGMA table_info(categories)"))
        }
        if "layout_type" not in category_cols:
            conn.execute(text("ALTER TABLE categories ADD COLUMN layout_type VARCHAR(30) DEFAULT 'list'"))


