# ── Articles ──────────────────────────────────────────────
@app.get("/api/articles", response_model=list[ArticleOut])
def list_articles(
    db: Session = Depends(get_db),
    published: Optional[bool] = None,
    category: Optional[str] = None,
    limit: int = 100,
    offset: int = 0,
):
    q = db.query(Article)
    if published is not None:
        q = q.filter(Article.is_published == published)
    if category:
        q = q.join(Category, Article.category_id == Category.id).filter(Category.slug == category)
    return q.order_by(Article.created_at.desc()).offset(offset).limit(limit).all()


