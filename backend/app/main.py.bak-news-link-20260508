# ── Upload ────────────────────────────────────────────────
def _save_media_upload(file: UploadFile) -> UploadResponse:
    suffix = Path(file.filename or "").suffix.lower()
    if suffix not in {".jpg", ".jpeg", ".png"}:
        raise HTTPException(status_code=400, detail="only .jpg/.jpeg/.png are supported")
    filename = f"{uuid.uuid4().hex}{suffix}"
    target = MEDIA_DIR / filename
    with target.open("wb") as buffer:
        shutil.copyfileobj(file.file, buffer)
    return UploadResponse(url=f"/static/media/{filename}")


@app.post("/admin/upload", response_model=UploadResponse)
def admin_upload_image(
    file: UploadFile = File(...),
    _: str = Depends(verify_admin),
):
    return _save_media_upload(file)


@app.post("/api/uploads", response_model=UploadResponse)
def upload_image(
    file: UploadFile = File(...),
    _: str = Depends(verify_admin),
):
    return _save_media_upload(file)


# ── Admin UI ──────────────────────────────────────────────
@app.get("/admin", response_class=HTMLResponse)
def admin_page(
    request: Request,
    db: Session = Depends(get_db),
    _: str = Depends(verify_admin),
):
    article_count = db.query(Article).count()
    album_count = db.query(Album).count()
    photo_count = db.query(Photo).count()
    category_count = db.query(Category).count()
    return templates.TemplateResponse(
        request=request,
        name="admin.html",
        context={
            "article_count": article_count,
            "album_count": album_count,
            "photo_count": photo_count,
            "category_count": category_count,
        },
    )


@app.get("/admin/data")
def admin_data(
    db: Session = Depends(get_db),
    _: str = Depends(verify_admin),
):
    articles = db.query(Article).order_by(Article.created_at.desc()).limit(50).all()
    albums = db.query(Album).order_by(Album.created_at.desc()).limit(50).all()
    photos = db.query(Photo).order_by(Photo.order.asc()).limit(200).all()
    categories = db.query(Category).order_by(Category.name_fr.asc()).all()
    return {
        "articles": [a.to_dict() for a in articles],
        "albums": [al.to_dict() for al in albums],
        "photos": [p.to_dict() for p in photos],
        "categories": [c.to_dict() for c in categories],
    }

